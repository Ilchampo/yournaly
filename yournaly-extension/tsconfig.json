{
	"extends": "./.wxt/tsconfig.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"target": "ES2022",
		"useDefineForClassFields": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",

		/* Path Mapping */
		"paths": {
			"@/*": ["./entrypoints/sidepanel/*"],
			"@components/*": ["./entrypoints/sidepanel/components/*"],
			"@pages/*": ["./entrypoints/sidepanel/pages/*"],
			"@lib/*": ["./entrypoints/sidepanel/lib/*"],
			"@stores/*": ["./entrypoints/sidepanel/lib/stores/*"],
			"@services/*": ["./entrypoints/sidepanel/lib/services/*"],
			"@interfaces/*": ["./entrypoints/sidepanel/lib/interfaces/*"],
			"@constants/*": ["./entrypoints/sidepanel/lib/constants/*"],
			"@utils/*": ["./entrypoints/sidepanel/lib/utils/*"],
			"@hooks/*": ["./entrypoints/sidepanel/hooks/*"]
		},

		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true
	}
}
