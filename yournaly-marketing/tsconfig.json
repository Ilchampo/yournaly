{
	"compilerOptions": {
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./src/*"],
			"@components/*": ["./src/app/components/*"],
			"@hooks/*": ["./src/app/hooks/*"],
			"@sections/*": ["./src/app/sections/*"],
			"@lib/*": ["./src/app/lib/*"],
			"@assets/*": ["./src/app/lib/assets/*"],
			"@constants/*": ["./src/app/lib/constants/*"],
			"@interfaces/*": ["./src/app/lib/interfaces/*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
