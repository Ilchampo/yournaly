# Application Configuration
NODE_ENV="development"
PORT=3000

# Database URLs for different environments
# App resolves DATABASE_URL_DEV / DATABASE_URL_PROD by NODE_ENV, then falls back to DATABASE_URL
DATABASE_URL="postgresql://username:password@localhost:5432/yournaly_dev"
DATABASE_URL_DEV="postgresql://username:password@localhost:5432/yournaly_dev"
DATABASE_URL_PROD="postgresql://username:password@production-host:5432/yournaly_prod"

# Database connection pool settings
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# OpenRouter Configuration (OpenAI-compatible SDK)
OPENAI_API_KEY="your_openrouter_api_key_here"
OPENAI_MODEL="openai/gpt-4.1-mini"
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
OPENAI_HTTP_REFERER="https://yournaly.pablobeltran.com"
OPENAI_APP_TITLE="Yournaly Extension"

# Stripe Configuration
STRIPE_SECRET_KEY="your_stripe_secret_key_here"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret_here"
STRIPE_SUCCESS_URL="http://localhost:3000/payment/success?session_id={CHECKOUT_SESSION_ID}"
STRIPE_CANCEL_URL="http://localhost:3000/payment/cancel"

# JWT Configuration (required, min 32 characters)
JWT_SECRET="replace_with_a_long_random_secret_at_least_32_chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Session Configuration
SESSION_SECRET="your_session_secret"

# Google OAuth Configuration (Chrome extension — Client ID only, no secret)
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_USER_INFO_URL="https://www.googleapis.com/oauth2/v2/userinfo"
GOOGLE_TOKEN_INFO_URL="https://oauth2.googleapis.com/tokeninfo"
