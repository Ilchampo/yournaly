{
  "name": "yournaly-backend",
  "version": "1.0.0",
  "description": "Project that handles the business logic of Yournaly",
  "keywords": [
    "education",
    "english",
    "learn",
    "AI",
    "grammar",
    "node",
    "express",
    "typescript"
  ],
  "homepage": "https://github.com/Ilchampo/yournaly#readme",
  "bugs": {
    "url": "https://github.com/Ilchampo/yournaly/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ilchampo/yournaly.git",
    "directory": "yournaly-backend"
  },
  "license": "ISC",
  "author": "Pablo Beltran",
  "type": "commonjs",
  "main": "index.js",
  "_moduleAliases": {
    "@": "dist"
  },
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc && cp -r src/generated dist/",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.js,.mjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "psql \"$DATABASE_URL\" -f scripts/seed.sql",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "@types/stripe": "^8.0.416",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "google-auth-library": "^10.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "morgan": "^1.10.0",
    "openai": "^5.8.2",
    "prisma": "^6.10.1",
    "stripe": "^18.3.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.7",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^51.2.3",
    "eslint-plugin-n": "^17.21.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "allowScripts": {
    "@prisma/client@6.10.1": true,
    "@prisma/engines@6.10.1": true,
    "prisma@6.10.1": true
  }
}
